@model FormUygulamasi.Models.Stok

@{
    ViewData["Title"] = "Stok Güncelle";
}

<h1 class="text-center form-title mb-3">Stok Güncelle</h1>
<div class="form-divider mx-auto mb-4"></div>

<div class="card shadow mx-auto" style="max-width: 950px;">
    <div class="card-body px-5">

        <form asp-controller="Stok" asp-action="StokGuncelle" method="post">

            <input asp-for="StokKodu" type="hidden" />

            <div class="mb-3">
                <label class="form-label">Stok Kodu</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-upc-scan"></i>
                    </span>

                    <input asp-for="StokKodu"
                           class="form-control"
                           readonly />

                </div>
            </div>

            <div class="mb-3">
                <label asp-for="StokAdi" class="form-label">Stok Adı</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-box"></i>
                    </span>

                    <input asp-for="StokAdi"
                           class="form-control"
                           placeholder="Stok adını giriniz." />

                </div>

                <span asp-validation-for="StokAdi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Barkod" class="form-label">Barkod</label>

                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-upc"></i>
                    </span>

                    <input asp-for="Barkod"
                           class="form-control"
                           placeholder="Barkod giriniz." />

                </div>

                <span asp-validation-for="Barkod" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="row">

                    <div class="col">
                        <label asp-for="BirimAdi" class="form-label">Birim Adı</label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-rulers"></i>
                            </span>

                            <input asp-for="BirimAdi"
                                   class="form-control"
                                   placeholder="Birim adı giriniz." />

                        </div>

                        <span asp-validation-for="BirimAdi" class="text-danger"></span>
                    </div>

                    <div class="col">
                        <label asp-for="Adet" class="form-label">Adet</label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-123"></i>
                            </span>

                            <input asp-for="Adet"
                                   type="number"
                                   min="0"
                                   class="form-control" />

                        </div>

                        <span asp-validation-for="Adet" class="text-danger"></span>
                    </div>

                </div>
            </div>

            <div class="mb-3">
                <div class="row">

                    <div class="col">
                        <label asp-for="AlisFiyati" class="form-label">Alış Fiyatı</label>

                        <div class="input-group">
                            <span class="input-group-text">₺</span>

                            <input asp-for="AlisFiyati"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   class="form-control" />

                        </div>

                        <span asp-validation-for="AlisFiyati" class="text-danger"></span>
                    </div>

                    <div class="col">
                        <label asp-for="SatisFiyati" class="form-label">Satış Fiyatı</label>

                        <div class="input-group">
                            <span class="input-group-text">₺</span>

                            <input asp-for="SatisFiyati"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   class="form-control" />

                        </div>

                        <span asp-validation-for="SatisFiyati" class="text-danger"></span>
                    </div>

                </div>
            </div>

            <div class="mb-3">
                <label asp-for="KdvOrani" class="form-label">KDV Oranı</label>

                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-percent"></i>
                    </span>

                    <select asp-for="KdvOrani" class="form-select">
                        <option value="1">%1</option>
                        <option value="10">%10</option>
                        <option value="20">%20</option>
                    </select>

                </div>

                <span asp-validation-for="KdvOrani" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 mb-3">

                <button type="submit" class="btn btn-warning">
                    Güncelle
                </button>

            </div>

        </form>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}